# Your Farcaster FID — gives you the "start the game" button in the waiting room
HOST_FID=your_fid_here

# Public base URL (no trailing slash)
# Local dev: leave empty, auto-detected
# Production: set to your Vercel URL
SNAP_PUBLIC_BASE_URL=https://snap-assassin.vercel.app

# Turso database (get these from turso.tech — free tier is fine)
# Local dev: leave TURSO_DATABASE_URL as file:assassin.db (no auth token needed)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Neynar API key — for username lookups and notifications (neynar.com)
NEYNAR_API_KEY=your_neynar_api_key_here
